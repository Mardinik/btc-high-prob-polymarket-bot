# =============================================================================
# Polymarket - High Probability Bot  |  .env.example
# Copia este archivo a .env y rellena tus valores reales.
# =============================================================================

# --- Credenciales (obligatorio) ---
POLYMARKET_PRIVATE_KEY=0x_tu_clave_privada_aqui
POLYMARKET_API_KEY=tu_api_key
POLYMARKET_API_SECRET=tu_api_secret
POLYMARKET_API_PASSPHRASE=tu_passphrase

# --- Tipo de firma ---
# 0 = EOA (MetaMask / hardware wallet)
# 1 = Magic.link (login con email en Polymarket)
# 2 = Gnosis Safe
POLYMARKET_SIGNATURE_TYPE=1

# --- Estrategia ---
ENTRY_PROB_THRESHOLD=0.78   # Probabilidad mínima para entrar (0.0 – 1.0)
POSITION_SIZE=5             # Shares a comprar por apuesta (mínimo 5)

# --- Modo simulación ---
DRY_RUN=true                # true = no coloca órdenes reales
SIM_BALANCE=100             # Balance inicial simulado en USD
