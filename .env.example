# .\.venv\Scripts\activate
# python -m src.test_balance
# python -m src.simple_arb_bot
# python -m src.high_prob_bot

# =============================================================================
# Polymarket API Credentials (required)
# =============================================================================
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_api_passphrase_here
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here
POLYMARKET_SIGNATURE_TYPE=1
POLYMARKET_FUNDER=

# =============================================================================
# Simulation Settings
# =============================================================================
DRY_RUN=true
SIM_BALANCE=350

# =============================================================================
# Bot General Configuration (arbitrage mode, order type, etc.)
# =============================================================================
TARGET_PAIR_COST=0.991
ORDER_SIZE=5
ORDER_TYPE=FOK
VERBOSE=false
COOLDOWN_SECONDS=10
POLYMARKET_MARKET_SLUG=
USE_WSS=false
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com

# =============================================================================
# Directional Mode Strategy
# =============================================================================
TRADE_MODE=directional
PROFIT_TARGET_PCT=6.0
STOP_LOSS_PCT=20.0

# --- Signal Mode -------------------------------------------------------------
# Choose 'confluence' or 'indicator_based'
# --- Signal Mode -------------------------------------------------------------
# ¿Cómo decide el bot cuándo comprar? Elige uno:
#   confluence (recomendado): usa la probabilidad combinada (TA + mercado)
#        + puntuación técnica. Más robusto, evita ir contra la tendencia.
#   indicator_based: solo mira los indicadores técnicos (RSI, MACD, etc.)
#        con pesos que tú asignas. Más flexible, pero más sensible a falsas señales.
SIGNAL_MODE=indicator_based

# --- Common Filters (applied in both modes) ----------------------------------
MAX_ENTRY_PRICE=0.97                  # Max price to buy (0.0-1.0)
MIN_TIME_LEFT_MINUTES=1.0            # Minimum minutes left to trade
MAX_POSITIONS=1                      # Simultaneous positions
COOLDOWN_AFTER_LOSS_SECONDS=15       # Wait after a loss before new entries

# --- Filters to avoid cheap bets near the end -------------------------------
MIN_PRICE_AT_END=0.20                # Minimum price allowed in last minutes
MIN_PRICE_APPLY_MINUTES=10.0         # Minutes before close to apply above filter

# --- Exit / Risk Management --------------------------------------------------
TAKE_PROFIT_TIMEOUT_SECONDS=45       # Max time in profit before exiting
TRAILING_PCT=2.0                     # Trailing stop percentage
EXIT_BEFORE_CLOSE_MINUTES=1.5        # Exit early if profit and market closing

# --- Confluence Mode Parameters (used when SIGNAL_MODE=confluence) ----------
MIN_TA_PROB=0.75                     # Minimum technical probability
TA_PROB_DIFF_MIN=0.20                # Minimum difference between UP and DOWN probabilities
TECH_SCORE_CONFLUENCE=7.0            # Minimum technical score (0-10)

# =============================================================================
# Indicator-Based Mode Parameters (commented, only used if SIGNAL_MODE=indicator_based)
# =============================================================================
WEIGHT_RSI=2.0
WEIGHT_MACD=5.0
WEIGHT_VWAP_SLOPE=3.0
WEIGHT_DELTA=5.0
WEIGHT_HEIKEN=1.0
INDICATOR_MIN_SCORE=5.0
RSI_UP_THRESHOLD=61.0
RSI_DOWN_THRESHOLD=40.0
RSI_EXTREME_BONUS=0.4
MACD_EXPANDING_BONUS=1.0
HEIKEN_CONSECUTIVE_BONUS=0.5
MAX_HEIKEN_BONUS=2.0

# =============================================================================
# Assistant State File (must match the path where the assistant writes it)
# =============================================================================
ASSISTANT_STATE_FILE=C:/Users/mrcsd/PolymarketBTC15mAssistant/assistant_state.json

# =============================================================================
# High porb bot parameters
# =============================================================================
POSITION_SIZE=5
ENTRY_PROB_THRESHOLD=0.78
HEDGE_PROB_THRESHOLD=0.78
MAX_BETS_PER_MARKET=4
HEDGE_MULTIPLIER=4
MIN_TIME_TO_OPERATE_SECONDS=0   # 0 = desactivado (operar hasta el final)
