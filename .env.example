# =============================================================================
# High-Confidence Bot  —  .env.example
# Copia a .env y rellena tus valores.
# Inicio: .\.venv\Scripts\activate  &&  python -m src.high_prob_bot
# =============================================================================

# --- Credenciales (obligatorio) ---
POLYMARKET_PRIVATE_KEY=0x_tu_clave_privada_aqui
POLYMARKET_API_KEY=tu_api_key
POLYMARKET_API_SECRET=tu_api_secret
POLYMARKET_API_PASSPHRASE=tu_passphrase
POLYMARKET_FUNDER=0xb1133Cbf8a89793b57c875b0eCD62162e840283E

# --- Tipo de firma ---
# 0 = EOA (MetaMask / hardware wallet)
# 1 = Magic.link (login con email en Polymarket)
POLYMARKET_SIGNATURE_TYPE=1

# =============================================================================
# ESTRATEGIA
# =============================================================================

# Probabilidad mínima implícita para entrar (0.0–1.0)
# 0.90 = solo entrar cuando el mercado asigna ≥90% a un lado
PROB_THRESHOLD=0.90

# Ventana de entrada:
#   - Solo operar si quedan MENOS de ENTRY_WINDOW_MAX_MIN minutos
#   - Solo operar si quedan MÁS de ENTRY_WINDOW_MIN_SEC segundos
ENTRY_WINDOW_MAX_MIN=5.0
ENTRY_WINDOW_MIN_SEC=45.0

# Shares por apuesta (mínimo 5 en Polymarket)
POSITION_SIZE=10

# Stop-loss: vender si el bid cae este % bajo el precio de entrada.
# 0.0 = desactivado. Con muy poco tiempo puede generar whipsaw.
STOP_LOSS_PCT=0.50

# =============================================================================
# OPERACIÓN
# =============================================================================

# Segundos entre cada ciclo de escaneo de precios
# 1.0 = escaneo cada segundo (recomendado)
# 0.5 = más agresivo, más llamadas a la API
POLL_INTERVAL_SEC=1.0

# =============================================================================
# SIMULACIÓN
# =============================================================================
DRY_RUN=true          # true = sin órdenes reales | false = trading real
SIM_BALANCE=400       # Balance inicial simulado en USD

